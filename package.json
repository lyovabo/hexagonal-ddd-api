{
  "name": "hexagonal-ddd-api",
  "version": "1.0.0",
  "description": "Production-ready Node.js API using Hexagonal Architecture, DDD, PostgreSQL, Redis, and Kafka",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/composition/main.js",
    "start:legacy": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/composition/main.ts",
    "dev:legacy": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:e2e": "jest tests/e2e",
    "migrate": "node dist/scripts/migrate.js",
    "migrate:dev": "ts-node scripts/migrate.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "docker:up": "docker compose up -d api postgres redis kafka zookeeper kafka-ui",
    "docker:up:dev": "docker compose up api-dev postgres redis kafka zookeeper kafka-ui",
    "docker:down": "docker compose down",
    "docker:build": "docker build -t hexagonal-ddd-api ."
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
